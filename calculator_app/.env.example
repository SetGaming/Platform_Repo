# Docker image configuration
COMPOSE_PROJECT_NAME=calculator-app
IMAGE_URI=calculator-app
IMAGE_TAG=local

# Application configuration
APP_PORT=5000
CONTAINER_PORT=5000
FLASK_ENV=production
FLASK_DEBUG=0

# Replace locally or inject through Jenkins Credentials
SECRET_KEY=replace-with-a-generated-secret
API_TOKEN=
DATABASE_URL=
ZOHO_API_KEY=

# Amazon Web Services configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_REPOSITORY=calculator-app
